# packages/db: relative to packages/db directory
DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="change-me-in-production"
DEEPSEEK_API_KEY=""
IMA_OPENAPI_CLIENTID=""
IMA_OPENAPI_APIKEY=""
IMA_BASE_URL="https://ima.qq.com"
AGNES_API_KEY=""
AGNES_BASE_URL="https://apihub.agnes-ai.com/v1"
AGNES_MODEL="agnes-2.0-flash"
AGNES_IMAGE_MODEL="agnes-image-2.0-flash"
# 图片生成引擎（IMAGE_PROVIDER）：agnes | doubao
# 架构：packages/image-provider 注册表 + 工厂，新增厂商实现 ImageProviderAdapter 并注册即可
IMAGE_PROVIDER="agnes"
USE_MOCK_AGNES_IMAGE=false
# 图片 API 调试日志（development 默认开启，可设 DEBUG_IMAGE=false 关闭）
DEBUG_IMAGE=true
DOUBAO_API_KEY=""
DOUBAO_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_IMAGE_MODEL="doubao-seedream-5-0-lite-260128"
USE_MOCK_DOUBAO_IMAGE=true
TURBOPUSH_BASE_URL="http://localhost:3000"
USE_MOCK_AI=false
USE_MOCK_IMA=false
USE_MOCK_TURBOPUSH=false
WEB_BASE_URL="http://localhost:3001"
API_BASE_URL="http://localhost:3001"
# 平台 OAuth（抖音/微信等）凭证请在系统内「账号管理 → OAuth 配置」填写，存入数据库，勿写进 .env
USE_MOCK_OAUTH=false
TOKEN_ENCRYPTION_KEY="dev-token-encryption-key-32chars!!"
